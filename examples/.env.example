# =============================================================================
# Iris Attestation API
# =============================================================================
# IRIS_API_URL=https://iris-api-sandbox.circle.com  # Default (sandbox)

# =============================================================================
# EVM Configuration (Arc Testnet by default)
# =============================================================================
# EVM USDC token contract address (Arc Testnet)
EVM_TOKEN_HEX=0x3600000000000000000000000000000000000000

# EVM CCTP domain ID (26 = Arc Testnet)
EVM_DOMAIN=26

# EVM chain ID (5042002 = Arc Testnet)
EVM_CHAIN_ID=5042002
EVM_CHAIN_NAME=Arc Testnet

# Your EVM wallet private key (address is derived automatically)
EVM_PRIVATE_KEY=

# EVM RPC URL
EVM_RPC_URL=https://rpc.testnet.arc.network

# EVM TokenMessengerV2 contract address (Arc Testnet)
EVM_TOKEN_MESSENGER_ADDRESS=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA

# EVM MessageTransmitterV2 contract address (Arc Testnet)
EVM_MESSAGE_TRANSMITTER_ADDRESS=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275

# =============================================================================
# Stellar Configuration
# =============================================================================
# Soroban RPC URL
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Your Stellar secret key (S...)
STELLAR_SECRET_KEY=

# =============================================================================
# Stellar CCTP Contract Addresses (Stellar Testnet)
# =============================================================================
# TokenMessengerMinterV2 contract ID (Stellar Testnet)
STELLAR_TOKEN_MESSENGER_MINTER_ADDRESS=CDNG7HXAPBWICI2E3AUBP3YZWZELJLYSB6F5CC7WLDTLTHVM74SLRTHP

# MessageTransmitterV2 contract ID (Stellar Testnet)
STELLAR_MESSAGE_TRANSMITTER_ADDRESS=CBJ6MTCKKZG73PMDZCJMSFRD7DQEMI4FKDH7CGDSV4W6FHCRBCQAVVJY

# USDC token contract ID (Stellar Testnet)
STELLAR_USDC_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# CctpForwarder contract ID (Stellar Testnet, required for EVM→Stellar).
# This address is set as both the mintRecipient and destinationCaller on the
# EVM burn. Usage of any other address for mintRecipient or destinationCaller
# can lead to stuck funds.
STELLAR_CCTP_FORWARDER_ADDRESS=CA66Q2WFBND6V4UEB7RD4SAXSVIWMD6RA4X3U32ELVFGXV5PJK4T4VSZ

# =============================================================================
# Optional (Stellar → EVM only)
# =============================================================================
# Destination caller for Stellar→EVM transfers — leave empty to allow any
# address to call receiveMessage on the EVM side.
# EVM_DESTINATION_CALLER=

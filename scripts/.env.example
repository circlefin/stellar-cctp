# Network Configuration (set manually for your target network)
STELLAR_RPC_URL=http://localhost:8000/soroban/rpc
NETWORK_PASSPHRASE="Standalone Network ; February 2017"
FRIENDBOT_URL=http://localhost:8000/friendbot
ALLOW_HTTP=true

# Optional — funder EOA for networks without Friendbot.
# When set, funds new accounts via direct XLM transfer instead of Friendbot.
EOA_FUNDER_SECRET=
EOA_FUNDER_PUBLIC=
# Minimum XLM balance to ensure for funded accounts (default: 1)
FUNDER_BALANCE_THRESHOLD=

# CCTP Deployer Account
EOA_CCTP_DEPLOYER_SECRET=
EOA_CCTP_DEPLOYER_PUBLIC=

# =============================================================================
# FiatTokenAdmin (inherited from stablecoin-common)
# =============================================================================

# FiatTokenAdmin Contract
FIAT_TOKEN_ADMIN_MINT_ASSET_CODE=USDC
FIAT_TOKEN_ADMIN_ALLOW_ASSET_CODE=USDCAllCCTP
# Optional — set for deterministic contract address across deploys. Auto-generated if empty.
FIAT_TOKEN_ADMIN_SALT=
FIAT_TOKEN_ADMIN_CONTRACT_ID=
FIAT_TOKEN_ADMIN_WASM_HASH=

# FiatTokenAdmin Role Accounts
EOA_FIAT_TOKEN_ADMIN_DEPLOYER_SECRET=
EOA_FIAT_TOKEN_ADMIN_DEPLOYER_PUBLIC=
EOA_FIAT_TOKEN_ADMIN_OWNER_SECRET=
EOA_FIAT_TOKEN_ADMIN_OWNER_PUBLIC=
EOA_FIAT_TOKEN_ADMIN_PAUSER_SECRET=
EOA_FIAT_TOKEN_ADMIN_PAUSER_PUBLIC=
EOA_FIAT_TOKEN_ADMIN_ADMIN_SECRET=
EOA_FIAT_TOKEN_ADMIN_ADMIN_PUBLIC=
EOA_FIAT_TOKEN_ADMIN_MINTER_ASSET_CONTROLLER_SECRET=
EOA_FIAT_TOKEN_ADMIN_MINTER_ASSET_CONTROLLER_PUBLIC=
EOA_FIAT_TOKEN_ADMIN_BLOCKLISTER_SECRET=
EOA_FIAT_TOKEN_ADMIN_BLOCKLISTER_PUBLIC=

# Minter Account
EOA_FIAT_TOKEN_ADMIN_MINTER_SECRET=
EOA_FIAT_TOKEN_ADMIN_MINTER_PUBLIC=

# Mint Asset (USDC)
EOA_USDC_ISSUER_SECRET=
EOA_USDC_ISSUER_PUBLIC=
ASSET_USDC_CONTRACT_ID=

# Allow Asset (USDCAllCCTP)
EOA_USDCALLCCTP_ISSUER_SECRET=
EOA_USDCALLCCTP_ISSUER_PUBLIC=
ASSET_USDCALLCCTP_CONTRACT_ID=

# =============================================================================
# MessageTransmitter
# =============================================================================

# Configuration
MESSAGE_TRANSMITTER_LOCAL_DOMAIN=27
MESSAGE_TRANSMITTER_VERSION=1
MESSAGE_TRANSMITTER_SIGNATURE_THRESHOLD=2
MESSAGE_TRANSMITTER_MAX_MESSAGE_BODY_SIZE=8192
# Comma-separated list of attester addresses (hex-encoded, no 0x prefix)
MESSAGE_TRANSMITTER_ATTESTERS=
# Comma-separated list of attester private keys (for local testing only)
MESSAGE_TRANSMITTER_ATTESTER_PRIVATE_KEYS=

# Optional — set for deterministic contract address across deploys. Auto-generated if empty.
MESSAGE_TRANSMITTER_SALT=
MESSAGE_TRANSMITTER_CONTRACT_ID=
MESSAGE_TRANSMITTER_WASM_HASH=

# Optional — override WASM binary path (defaults to target/wasm32v1-none/release/)
MESSAGE_TRANSMITTER_WASM_PATH=

# MessageTransmitter Role Accounts
EOA_MESSAGE_TRANSMITTER_OWNER_SECRET=
EOA_MESSAGE_TRANSMITTER_OWNER_PUBLIC=
EOA_MESSAGE_TRANSMITTER_PAUSER_SECRET=
EOA_MESSAGE_TRANSMITTER_PAUSER_PUBLIC=
EOA_MESSAGE_TRANSMITTER_ADMIN_SECRET=
EOA_MESSAGE_TRANSMITTER_ADMIN_PUBLIC=
EOA_MESSAGE_TRANSMITTER_RESCUER_SECRET=
EOA_MESSAGE_TRANSMITTER_RESCUER_PUBLIC=
EOA_MESSAGE_TRANSMITTER_ATTESTER_MANAGER_SECRET=
EOA_MESSAGE_TRANSMITTER_ATTESTER_MANAGER_PUBLIC=

# =============================================================================
# TokenMessengerMinter
# =============================================================================

# Configuration
TOKEN_MESSENGER_MINTER_MESSAGE_BODY_VERSION=1
# Comma-separated remote domains, token messengers, and tokens (parallel arrays)
TOKEN_MESSENGER_MINTER_REMOTE_DOMAINS=
TOKEN_MESSENGER_MINTER_REMOTE_TOKEN_MESSENGERS=
TOKEN_MESSENGER_MINTER_REMOTE_TOKENS=
TOKEN_MESSENGER_MINTER_LOCAL_TOKEN_CODE=USDC
TOKEN_MESSENGER_MINTER_LOCAL_DECIMALS=7
TOKEN_MESSENGER_MINTER_CANONICAL_DECIMALS=6
TOKEN_MESSENGER_MINTER_MAX_BURN_AMOUNT=1000000000

# Optional — set for deterministic contract address across deploys. Auto-generated if empty.
TOKEN_MESSENGER_MINTER_SALT=
TOKEN_MESSENGER_MINTER_CONTRACT_ID=
TOKEN_MESSENGER_MINTER_WASM_HASH=

# Optional — override WASM binary path (defaults to target/wasm32v1-none/release/)
TOKEN_MESSENGER_MINTER_WASM_PATH=

# TokenMessengerMinter Role Accounts
EOA_TOKEN_MESSENGER_MINTER_OWNER_SECRET=
EOA_TOKEN_MESSENGER_MINTER_OWNER_PUBLIC=
EOA_TOKEN_MESSENGER_MINTER_PAUSER_SECRET=
EOA_TOKEN_MESSENGER_MINTER_PAUSER_PUBLIC=
EOA_TOKEN_MESSENGER_MINTER_ADMIN_SECRET=
EOA_TOKEN_MESSENGER_MINTER_ADMIN_PUBLIC=
EOA_TOKEN_MESSENGER_MINTER_RESCUER_SECRET=
EOA_TOKEN_MESSENGER_MINTER_RESCUER_PUBLIC=
EOA_TOKEN_MESSENGER_MINTER_TOKEN_CONTROLLER_SECRET=
EOA_TOKEN_MESSENGER_MINTER_TOKEN_CONTROLLER_PUBLIC=
EOA_TOKEN_MESSENGER_MINTER_FEE_RECIPIENT_SECRET=
EOA_TOKEN_MESSENGER_MINTER_FEE_RECIPIENT_PUBLIC=
EOA_TOKEN_MESSENGER_MINTER_MIN_FEE_CONTROLLER_SECRET=
EOA_TOKEN_MESSENGER_MINTER_MIN_FEE_CONTROLLER_PUBLIC=
EOA_TOKEN_MESSENGER_MINTER_DENYLISTER_SECRET=
EOA_TOKEN_MESSENGER_MINTER_DENYLISTER_PUBLIC=

# =============================================================================
# CctpForwarder
# =============================================================================

# Configuration
CCTP_FORWARDER_EXPECTED_MESSAGE_VERSION=1
CCTP_FORWARDER_EXPECTED_BURN_MESSAGE_VERSION=1

# Optional — set for deterministic contract address across deploys. Auto-generated if empty.
CCTP_FORWARDER_SALT=
CCTP_FORWARDER_CONTRACT_ID=
CCTP_FORWARDER_WASM_HASH=

# Optional — override WASM binary path (defaults to target/wasm32v1-none/release/)
CCTP_FORWARDER_WASM_PATH=

# CctpForwarder Role Accounts
EOA_CCTP_FORWARDER_OWNER_SECRET=
EOA_CCTP_FORWARDER_OWNER_PUBLIC=
EOA_CCTP_FORWARDER_PAUSER_SECRET=
EOA_CCTP_FORWARDER_PAUSER_PUBLIC=
EOA_CCTP_FORWARDER_ADMIN_SECRET=
EOA_CCTP_FORWARDER_ADMIN_PUBLIC=
EOA_CCTP_FORWARDER_RESCUER_SECRET=
EOA_CCTP_FORWARDER_RESCUER_PUBLIC=
